{
  "name": "marco-harness",
  "version": "0.4.0",
  "description": "Model-Agnostic Runtime for Controlled Orchestration — a small, readable AI agent harness.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "example": "tsx examples/mini-claude-code/src/bin.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.55.0"
  },
  "devDependencies": {
    "zod": "^3.24.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "tsx": "^4.19.0",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "ai",
    "ai-agent",
    "agent",
    "anthropic",
    "claude",
    "harness",
    "tools",
    "tool-use",
    "llm",
    "orchestration"
  ],
  "author": "Karan Kochar <karankochar13@gmail.com> (https://karankochar.dev)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyrotank41/MARCO.git"
  },
  "bugs": {
    "url": "https://github.com/pyrotank41/MARCO/issues"
  },
  "homepage": "https://github.com/pyrotank41/MARCO#readme"
}
